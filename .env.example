# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-token-here

# Optional comma-separated Telegram user IDs; leave empty to allow any user
ALLOWED_USER_IDS=123456789

# Telegram API credentials for the local Bot API server
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Claude runtime
DEFAULT_PROJECT=/projects
DEFAULT_MODEL=sonnet
DEFAULT_EFFORT=high
MAX_TURNS=10
STREAM_INTERVAL_MS=150
CLAUDE_PERMISSION_MODE=bypassPermissions
STATE_DB_PATH=/settings/state.sqlite3
TEMP_DIR=/temp
OUTBOX_DIR=/temp/outbox
LOCAL_BOT_API_STORAGE_PATH=/var/lib/telegram-bot-api
POLL_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

# LLM / tool integrations exposed to Claude
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
SIMPLEFIN_ACCESS_URL=
SPLITWISE_API_KEY=
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
TODOIST_API_KEY=

# Obsidian Sync sidecar
OBSIDIAN_VAULT_NAMES=
OBSIDIAN_AUTH_TOKEN=
OBSIDIAN_EMAIL=
OBSIDIAN_PASSWORD=
OBSIDIAN_VAULT_PASSWORD=
