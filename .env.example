# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-token-here

# Your Telegram user ID (get from @userinfobot)
ALLOWED_USER_IDS=123456789

# Anthropic API key (if not using Claude Pro/Max subscription auth)
ANTHROPIC_API_KEY=

# Telegram API credentials — get from https://my.telegram.org/apps
# Required for the local Bot API server (lifts the 20MB download / 50MB upload limits to 2GB)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ---------------------------------------------------------------------------
# Obsidian Sync (headless) — optional
# ---------------------------------------------------------------------------
# Comma-separated list of vault names to sync (exact names from Obsidian Sync)
OBSIDIAN_VAULT_NAMES=

# Authentication — choose one method:
#
#   Option A (recommended): pre-obtained auth token
OBSIDIAN_AUTH_TOKEN=

#   Option B: email + password (token is fetched and cached on first run)
OBSIDIAN_EMAIL=
OBSIDIAN_PASSWORD=

# Vault end-to-end encryption password (only if E2E encryption is enabled)
OBSIDIAN_VAULT_PASSWORD=

# ---------------------------------------------------------------------------
# Third-party integrations — optional
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
SIMPLEFIN_ACCESS_URL=
SPLITWISE_API_KEY=
SPLITWISE_CONSUMER_KEY=
SPLITWISE_CONSUMER_SECRET=
TODOIST_API_KEY=
